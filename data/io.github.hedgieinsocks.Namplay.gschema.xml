<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.hedgieinsocks.Namplay" path="/io/github/hedgieinsocks/Namplay/">
    <key name="window-width" type="i">
      <default>600</default>
      <summary>Window width in pixels</summary>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
      <summary>Window height in pixels</summary>
    </key>
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Whether the window is maximized</summary>
    </key>
    <key name="collapse-on-launch" type="b">
      <default>false</default>
      <summary>Collapse all expandable rows on launch</summary>
    </key>

    <key name="noise-gate-enabled" type="b">
      <default>false</default>
      <summary>Noise gate enabled</summary>
    </key>
    <key name="noise-gate-threshold" type="d">
      <range min="-80" max="-20"/>
      <default>-55</default>
      <summary>Noise gate threshold in dB</summary>
    </key>

    <key name="amp-profile-path" type="s">
      <default>''</default>
      <summary>Path to the selected amp profile file</summary>
    </key>
    <key name="ir-path" type="s">
      <default>''</default>
      <summary>Path to the selected impulse response file</summary>
    </key>
    <key name="ir-level" type="d">
      <range min="-20" max="20"/>
      <default>-18</default>
      <summary>Impulse response output level in dB</summary>
    </key>
    <key name="amp-profile-input" type="d">
      <range min="-20" max="20"/>
      <default>0</default>
      <summary>Amp profile input gain in dB</summary>
    </key>
    <key name="amp-profile-output" type="d">
      <range min="-20" max="20"/>
      <default>0</default>
      <summary>Amp profile output gain in dB</summary>
    </key>

    <key name="eq-enabled" type="b">
      <default>false</default>
      <summary>EQ enabled</summary>
    </key>
    <key name="eq-pre" type="b">
      <default>true</default>
      <summary>EQ position: pre or post</summary>
    </key>
    <key name="eq-low" type="d">
      <range min="-20" max="20"/>
      <default>0</default>
      <summary>EQ low band gain in dB</summary>
    </key>
    <key name="eq-mid" type="d">
      <range min="-20" max="20"/>
      <default>0</default>
      <summary>EQ mid band gain in dB</summary>
    </key>
    <key name="eq-high" type="d">
      <range min="-20" max="20"/>
      <default>0</default>
      <summary>EQ high band gain in dB</summary>
    </key>
    <key name="eq-hp" type="d">
      <range min="20" max="120"/>
      <default>70</default>
      <summary>EQ high-pass filter cutoff in Hz</summary>
    </key>
    <key name="eq-lp" type="d">
      <range min="5000" max="16000"/>
      <default>7000</default>
      <summary>EQ low-pass filter cutoff in Hz</summary>
    </key>
  </schema>
</schemalist>
